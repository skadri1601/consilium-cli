{
  "name": "@myconsilium/cli",
  "version": "0.5.0",
  "description": "CLI for Consilium AI Council - Multi-agent debate platform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "consilium": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "deliberation",
    "multi-agent",
    "debate",
    "consilium",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/skadri1601/consilium-cli.git"
  },
  "homepage": "https://github.com/skadri1601/consilium-cli#readme",
  "bugs": {
    "url": "https://github.com/skadri1601/consilium-cli/issues"
  },
  "author": "Saad Kadri <saad@myconsilium.xyz>",
  "license": "MIT",
  "dependencies": {
    "@consilium/shared": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "eventsource": "^4.1.0",
    "log-update": "^8.0.0",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "files": [
    "dist",
    "completions",
    "man",
    "README.md",
    "LICENSE"
  ]
}
